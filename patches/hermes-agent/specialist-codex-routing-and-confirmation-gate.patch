 from typing import Any, Dict, List
 
 logger = logging.getLogger(__name__)
 
 
+_PLAN_ONLY_DIRECTIVE = """<confirmation_gate>
+CONFIRMATION_GATE: PLAN_ONLY
+This is a direct user-facing session and execution has not been approved after a plan.
+If the request is purely informational, answer it directly without tools.
+If the request could cause any side effect, Do not call tools, execute commands, edit files, invoke implementation agents, or change external/local state. Produce a concrete pro-max plan with goal, approach, expected files/side effects, risks, and verification. End with the exact standalone marker NEEDS_CONFIRMATION and ask the user to approve before execution.
+The inline chat plan is the approval contract. Do not create, update, attach, or resend PLAN.md, PLANS.md, or files under .hermes/plans unless the user explicitly requested a saved plan artifact.
+The initial words fix/refactor/improve/build/configure are not approval.
+</confirmation_gate>
+
+"""
+
+_APPROVED_SCOPE_DIRECTIVE = """<confirmation_gate>
+CONFIRMATION_GATE: APPROVED_SCOPE
+The user explicitly approved after reviewing the previous plan. Now execute the previously proposed scope without asking again. Stay within that scope, preserve unrelated work, verify real results, and stop for new confirmation if scope materially expands.
+The approved inline chat plan is the execution contract. Do not create, update, attach, or resend PLAN.md, PLANS.md, or files under .hermes/plans unless the user explicitly requested a saved plan artifact.
+</confirmation_gate>
+
+"""
+
+
+def _message_text(message: Dict[str, Any]) -> str:
+    content = message.get("content", "") if isinstance(message, dict) else ""
+    if isinstance(content, str):
+        return content
+    if isinstance(content, list):
+        parts: list[str] = []
+        for item in content:
+            if isinstance(item, dict) and isinstance(item.get("text"), str):
+                parts.append(item["text"])
+        return "\n".join(parts)
+    return ""
+
+
+def _fold_confirmation_text(value: str) -> str:
+    """Normalize chat wording while preserving words needed for intent checks."""
+    normalized = str(value or "").strip().lower().replace("đ", "d")
+    normalized = "".join(
+        char
+        for char in unicodedata.normalize("NFD", normalized)
+        if unicodedata.category(char) != "Mn"
+    )
+    normalized = normalized.replace("’", "'")
+    normalized = re.sub(r"\bdon't\b", "dont", normalized)
+    return re.sub(r"[^a-z0-9]+", " ", normalized).strip()
+
+
+def _has_execution_approval_intent(user_message: str) -> bool:
+    """Classify explicit approval by intent, not by whole-sentence literals.
+
+    This is deliberately bounded: it recognizes authorization or an imperative
+    to begin the already-proposed work, while scoped denial/hold language wins.
+    The caller still requires a preceding ``NEEDS_CONFIRMATION`` boundary.
+    """
+    text = _fold_confirmation_text(user_message)
+    if not text:
+        return False
+
+    execution_terms = (
+        r"approve|authorize|permission|proceed|execute|implement|start|begin|"
+        r"change|edit|dong y|phe duyet|cho phep|chap nhan|xac nhan|duoc duyet|"
+        r"sua|lam|thuc hien|thuc thi|trien khai|tien hanh|code"
+    )
+    denial_patterns = (
+        rf"\b(?:do not|dont|never)\s+(?:\w+\s+){{0,3}}(?:{execution_terms})\b",
+        r"\bnot\s+approved\b",
+        rf"\b(?:khong|chua|dung)\s+(?:\w+\s+){{0,3}}(?:{execution_terms})\b",
+        r"\b(?:khoan|dung lai|tu choi|wait|hold on|stop|cancel)\b",
+    )
+    if any(re.search(pattern, text) for pattern in denial_patterns):
+        return False
+
+    approval_patterns = (
+        r"\b(?:ok|okay|yes)\b",
+        r"\b(?:approve|approved|authorize|authorized)\b",
+        r"\b(?:permission|authorization)\s+(?:is\s+)?(?:granted|given)\b",
+        r"\byou have my (?:permission|authorization)\b",
+        r"\b(?:please\s+)?proceed\b|\bgo ahead\b",
+        r"\b(?:execute|implement)\b",
+        r"\b(?:start|begin)\s+(?:the\s+)?(?:implementation|execution|work|changes)\b",
+        r"\bmake\s+(?:the\s+)?(?:proposed|approved)\s+changes\b",
+        r"\b(?:dong y|phe duyet|cho phep|chap nhan|xac nhan|duoc duyet)\b",
+        r"\b(?:sua|lam|thuc hien|thuc thi|trien khai|tien hanh)\b",
+        r"\bbat tay vao (?:code|lam|thuc hien)\b",
+        r"\bchuyen sang che do (?:thuc thi|execute|agent)\b",
+    )
+    return any(re.search(pattern, text) for pattern in approval_patterns)
+
+
+def _confirmation_gate_state(
+    user_message: str, messages: List[Dict[str, Any]]
+) -> tuple[bool, bool, str]:
+    """Return (approved, delegated, previous_confirmation_plan) for this turn."""
+    raw = str(user_message or "")
+    folded = _fold_confirmation_text(raw)
+    delegated_approval = folded.startswith("cho phep sua")
+    previous_assistant = ""
+    for message in reversed(messages or []):
+        if isinstance(message, dict) and message.get("role") == "assistant":
+            candidate = _message_text(message)
+            if "NEEDS_CONFIRMATION" in candidate:
+                previous_assistant = candidate
+                break
+    approved_after_plan = bool(previous_assistant) and _has_execution_approval_intent(raw)
+    return delegated_approval or approved_after_plan, delegated_approval, previous_assistant
+
+
+def _confirmation_gate_is_approved(
+    user_message: str, messages: List[Dict[str, Any]]
+) -> bool:
+    return _confirmation_gate_state(user_message, messages)[0]
+
+
+def _confirmation_gated_codex_input(
+    user_message: str, messages: List[Dict[str, Any]]
+) -> str:
+    """Add a hard planning/approval boundary to a Codex app-server turn."""
+    raw = str(user_message or "")
+    approved, delegated_approval, previous_assistant = _confirmation_gate_state(
+        raw, messages
+    )
+
+    if delegated_approval:
+        return _APPROVED_SCOPE_DIRECTIVE + raw
+
+    if approved:
+        original_request = ""
+        for message in messages or []:
+            if isinstance(message, dict) and message.get("role") == "user":
+                candidate = _message_text(message).strip()
+                if candidate and candidate != raw.strip():
+                    original_request = candidate
+                    break
+        replay = (
+            "<approved_context>\n"
+            f"ORIGINAL_REQUEST:\n{original_request}\n\n"
+            f"APPROVED_PLAN:\n{previous_assistant}\n"
+            "</approved_context>\n\n"
+        )
+        return _APPROVED_SCOPE_DIRECTIVE + replay + raw
+    return _PLAN_ONLY_DIRECTIVE + raw
+
+
