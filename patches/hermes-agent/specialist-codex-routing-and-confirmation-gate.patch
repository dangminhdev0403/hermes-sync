+def resolve_codex_binary(codex_bin: str = "codex", *, env: Optional[dict[str, str]] = None) -> str:
+    """Return an executable Codex CLI path for the current spawn environment.
+
+    On Windows, subprocess with a custom env does not reliably resolve npm
+    command shims from the bare name. Resolve against the same PATH that will
+    be used for the child so nvm/npm installs such as codex.cmd work from
+    gateway, cron, and specialist worker contexts.
+    """
+    if os.path.isabs(codex_bin) or os.sep in codex_bin or (os.altsep and os.altsep in codex_bin):
+        return codex_bin
+    search_path = (env or os.environ).get("PATH")
+    found = shutil.which(codex_bin, path=search_path)
+    if found:
+        return found
+    if os.name == "nt" and not codex_bin.lower().endswith((".cmd", ".bat", ".exe")):
+        for suffix in (".cmd", ".bat", ".exe"):
+            found = shutil.which(codex_bin + suffix, path=search_path)
+            if found:
+                return found
+    return codex_bin
+
+
