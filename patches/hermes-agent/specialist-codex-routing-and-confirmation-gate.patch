 logger = logging.getLogger(__name__)
 
 
+_PLAN_ONLY_DIRECTIVE = """<confirmation_gate>
+CONFIRMATION_GATE: PLAN_ONLY
+This is a direct user-facing session and execution has not been approved after a plan.
+If the request is purely informational, answer it directly without tools.
+If the request could cause any side effect, Do not call tools, execute commands, edit files, invoke implementation agents, or change external/local state. Produce a concrete pro-max plan with goal, approach, expected files/side effects, risks, and verification. End with the exact standalone marker NEEDS_CONFIRMATION and ask the user to approve before execution.
+The initial words fix/refactor/improve/build/configure are not approval.
+</confirmation_gate>
+
+"""
+
+_APPROVED_SCOPE_DIRECTIVE = """<confirmation_gate>
+CONFIRMATION_GATE: APPROVED_SCOPE
+The user explicitly approved after reviewing the previous plan. Now execute the previously proposed scope without asking again. Stay within that scope, preserve unrelated work, verify real results, and stop for new confirmation if scope materially expands.
+</confirmation_gate>
+
+"""
+
+
+def _message_text(message: Dict[str, Any]) -> str:
+    content = message.get("content", "") if isinstance(message, dict) else ""
+    if isinstance(content, str):
+        return content
+    if isinstance(content, list):
+        parts: list[str] = []
+        for item in content:
+            if isinstance(item, dict) and isinstance(item.get("text"), str):
+                parts.append(item["text"])
+        return "\n".join(parts)
+    return ""
+
+
+def _confirmation_gate_state(
+    user_message: str, messages: List[Dict[str, Any]]
+) -> tuple[bool, bool, str]:
+    """Return (approved, delegated, previous_assistant) for this turn."""
+    raw = str(user_message or "")
+    normalized = raw.strip().lower()
+    delegated_approval = normalized.startswith("cho phép sửa")
+    explicit_approval = normalized in {
+        "ok", "okay", "đồng ý", "làm đi", "triển khai", "chấp nhận",
+        "ok làm đi", "ok triển khai", "đồng ý triển khai", "xác nhận",
+    } or normalized.startswith(("ok ", "đồng ý ", "triển khai ", "làm đi "))
+    previous_assistant = ""
+    for message in reversed(messages or []):
+        if isinstance(message, dict) and message.get("role") == "assistant":
+            previous_assistant = _message_text(message)
+            break
+    approved_after_plan = explicit_approval and "NEEDS_CONFIRMATION" in previous_assistant
+    return delegated_approval or approved_after_plan, delegated_approval, previous_assistant
+
+
+def _confirmation_gate_is_approved(
+    user_message: str, messages: List[Dict[str, Any]]
+) -> bool:
+    return _confirmation_gate_state(user_message, messages)[0]
+
+
+def _confirmation_gated_codex_input(
+    user_message: str, messages: List[Dict[str, Any]]
+) -> str:
+    """Add a hard planning/approval boundary to a Codex app-server turn."""
+    raw = str(user_message or "")
+    approved, delegated_approval, previous_assistant = _confirmation_gate_state(
+        raw, messages
+    )
+
+    if delegated_approval:
+        return _APPROVED_SCOPE_DIRECTIVE + raw
+
+    if approved:
+        original_request = ""
+        for message in messages or []:
+            if isinstance(message, dict) and message.get("role") == "user":
+                candidate = _message_text(message).strip()
+                if candidate and candidate != raw.strip():
+                    original_request = candidate
+                    break
+        replay = (
+            "<approved_context>\n"
+            f"ORIGINAL_REQUEST:\n{original_request}\n\n"
+            f"APPROVED_PLAN:\n{previous_assistant}\n"
+            "</approved_context>\n\n"
+        )
+        return _APPROVED_SCOPE_DIRECTIVE + replay + raw
+    return _PLAN_ONLY_DIRECTIVE + raw
+
+
