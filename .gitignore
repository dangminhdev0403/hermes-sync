# Hermes runtime/cache directories (re-created by install/runtime)
cache/
sessions/
cron/
gateway/
kanban/
logs/
lsp/
node/
gateway-service/
git/
bin/
image_cache/
audio_cache/
**/cache/
**/sessions/
**/cron/
**/logs/

# Node/build artifacts from tools or skills
node_modules/
**/node_modules/
.next/
**/.next/
dist/
**/dist/
coverage/
**/coverage/
.pnpm-store/
**/.pnpm-store/

# Local install configuration and credentials: never sync raw runtime config
# Keep shareable setup notes/templates in docs/ or *.example.yaml instead.
config.yaml
profiles/config.yaml
profiles/*/config.yaml
.env
**/.env
auth.json
**/auth.json
*.pem
*.key
*.p12
*.pfx

# Runtime databases, locks, pids, and evidence stores
*.db
*.db-shm
*.db-wal
*.lock
*.pid
verification_evidence.db
**/verification_evidence.db
processes.json
**/processes.json

# Generated runtime state/cache files
.update_check
**/.update_check
.skills_prompt_snapshot.json
**/.skills_prompt_snapshot.json
context_length_cache.yaml
models_dev_cache.json
provider_models_cache.json
ollama_cloud_models_cache.json
gateway_state.json
channel_directory.json
state/

# Skill manager runtime metadata; keep actual skill content, ignore usage/cache state
skills/.usage.json
skills/.usage.json.lock
skills/.hub/
skills/.backups/
profiles/*/skills/.usage.json
profiles/*/skills/.usage.json.lock
profiles/*/skills/.hub/
profiles/*/skills/.backups/
*.backup-before-reorg/
**/*.backup-before-reorg/
**/skills/.curator_state

# Nested repository backups
**/.git.backup
**/.git.backup.zip

# Misc logs
*.log
*.logs
